{
  "name": "context-engine",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "prisma generate --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "build": "pnpm generate && tsc",
    "dev": "pnpm generate && tsc --watch"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.83",
    "@ai-sdk/provider": "^3.0.8",
    "@prisma/adapter-better-sqlite3": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "ai": "^6.0.105",
    "dedent": "^1.7.1",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "prisma": "^6.19.3",
    "typescript": "^5.9.3"
  }
}
